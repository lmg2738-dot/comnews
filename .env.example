# 로컬: 이 파일을 .env.local 로 복사 후 값 입력 (Git 커밋 금지)
# Vercel: Project → Settings → Environment Variables (docs/VERCEL-ENV.md)

# 필수 — 텔레그램
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# 필수 — Upstash Redis
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# 선택 — 뉴스 키워드 OR 검색 (쉼표 구분, 기본 CJ)
# 예: CJ,롯데 → CJ 검색 결과 + 롯데 검색 결과 (각각 따로 검색)
NEWS_KEYWORDS=CJ

# 권장 — /api/cron 보호 (cron-job.org 백업 시)
CRON_SECRET=

# 선택 — GitHub API 저장·Actions 트리거 (Vercel에서 Redis 쓰면 불필요)
GITHUB_TOKEN=
GITHUB_REPOSITORY=lmg2738-dot/news
STATE_BRANCH=main

# 로컬에서 Vercel 배치 원격 호출 시
APP_URL=https://news-iota-peach.vercel.app
