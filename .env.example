# 로컬: 이 파일을 .env.local 로 복사 후 값 입력 (Git 커밋 금지)
# Vercel: Project → Settings → Environment Variables (docs/VERCEL-ENV.md)

# 필수 — 텔레그램
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# 필수 — Upstash Redis
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# 선택 — 같은 Upstash를 여러 프로젝트가 쓸 때 (docs/SHARED-UPSTASH.md)
# 기본 com → Redis 키 com-news:state (CJ 원본은 cj → cj-news:state)
REDIS_INSTANCE_ID=com
# REDIS_STATE_KEY=

# ★ 검색 키워드 (쉼표 구분) — 화면·수집에 사용. 변경 후 재배포 필수.
# KEYWORD_FETCH_CONCURRENCY 와 혼동하지 마세요 (그건 동시 수집 개수만).
NEWS_KEYWORDS=CJ

# 선택 — 키워드 동시 수집 수만 설정 (키워드 목록 아님, 기본 8, 최대 32)
KEYWORD_FETCH_CONCURRENCY=8

# 권장 — /api/cron 보호 (cron-job.org 백업 시)
CRON_SECRET=

# 선택 — GitHub API 저장·Actions 트리거 (Vercel에서 Redis 쓰면 불필요)
GITHUB_TOKEN=
GITHUB_REPOSITORY=lmg2738-dot/comnews
STATE_BRANCH=main

# 로컬에서 Vercel 배치 원격 호출 시
APP_URL=https://news-iota-peach.vercel.app
